# =============================================================================
# SERVER ENVIRONMENT VARIABLES - Copy this file to .env and fill in values
# =============================================================================

# --- Database (Neon PostgreSQL) ---
# Get this from https://console.neon.tech after creating a project
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# --- Better Auth ---
# Generate a random secret: openssl rand -hex 32
BETTER_AUTH_SECRET="your-random-secret-here"
# The public URL of your backend (Render URL in production)
BETTER_AUTH_URL="https://your-backend.onrender.com"
# Comma-separated list of allowed origins (frontend URLs)
TRUSTED_ORIGIN="http://localhost:5173,https://your-frontend.vercel.app"

# --- AI API (OpenRouter) ---
# Get from https://openrouter.ai/keys
AI_API_KEY="sk-or-v1-xxxxxxxxxxxx"

# --- Stripe (for payments) ---
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxx"
# Get from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"

# --- Environment ---
NODE_ENV="production"

# --- AI Model ---
# Configurable model ID from OpenRouter. E.g., 'kwaipilot/kat-coder-pro-v2', 'cohere/north-mini-code:free', etc.
AI_MODEL="kwaipilot/kat-coder-pro-v2"
